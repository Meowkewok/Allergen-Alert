{
  "manifest_version": 3,
  "name": "Allergen Alert",
  "version": "1.0",
  "description": "An Allergen detector.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "activeTab", 
    "storage",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
